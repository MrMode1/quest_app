# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/questivity

# --- AI provider ---
# Default provider is Claude (Anthropic). Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...
# Optional: override the Claude model used for extraction
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Only needed if you switch the extractor back to OpenAI
# (change the import in server/routes.ts from "./lib/ai" to "./lib/openai")
OPENAI_API_KEY=sk-...

# Any random string used to sign sessions
SESSION_SECRET=change-me-to-a-long-random-string

# Optional: server port (defaults to 5000)
PORT=5000
